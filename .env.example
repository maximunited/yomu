# =============================================================================
# YomU Environment Variables Template
# =============================================================================
# Copy this file to .env and update with your actual values
# Never commit your .env file to Git!

# =============================================================================
# DATABASE (PostgreSQL Required)
# =============================================================================

# IMPORTANT: This project uses PostgreSQL only (SQLite is NOT supported)
# Choose ONE of the following options:

# Option 1: Docker Compose (Recommended for local development)
# Use if running: ./scripts/docker-setup.sh start-dev
DATABASE_URL=postgresql://yomu:yomu@localhost:5432/yomu

# Option 2: Vercel Postgres (Development Database)
# Get from: vercel env pull .env
# DATABASE_URL=postgres://default:xxxxx@xxxxx.postgres.vercel-storage.com:5432/verceldb?sslmode=require

# Option 3: Manual PostgreSQL Installation
# Update with your local PostgreSQL credentials
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/yomu

# =============================================================================
# NEXTAUTH CONFIGURATION
# =============================================================================

# Application URL
NEXTAUTH_URL=http://localhost:3000

# Secret for JWT encryption (generate with: openssl rand -base64 32)
# CRITICAL: Change this in production!
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# =============================================================================
# OAUTH PROVIDERS (Optional)
# =============================================================================

# Google OAuth (Optional - only if enabling Google sign-in)
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# =============================================================================
# NOTES
# =============================================================================
# See QUICKSTART.md for step-by-step setup instructions
# See CLAUDE.md for detailed PostgreSQL setup options
# See docs/DATABASE_MIGRATION.md for database architecture details
