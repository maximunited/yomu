# Database
# For Docker development (PostgreSQL)
DATABASE_URL=postgresql://yomu:yomu@localhost:5432/yomu

# For production (Vercel Postgres - get from Vercel dashboard)
# DATABASE_URL=postgres://user:password@host/database?sslmode=require

# Note: The project uses PostgreSQL (not SQLite) for Docker environments.
# When running with docker-compose, the database service is available at 'db:5432'

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth (Optional - for Google sign-in)
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Note: Never commit your .env file to Git!
# This .env.example is just a template showing required variables.
