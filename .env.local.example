# YomU Local Development Environment Variables
# Copy this file to .env.local and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL Required)
# =============================================================================

# Option 1: Docker Compose PostgreSQL (Recommended for local development)
# Use this if you run: ./scripts/docker-setup.sh start-dev
DATABASE_URL="postgresql://yomu:yomu@localhost:5432/yomu"

# Option 2: Vercel Postgres (Development Database)
# Pull from Vercel: vercel env pull .env.local
# DATABASE_URL="postgres://default:xxxxx@xxxxx-pooler.us-east-1.postgres.vercel-storage.com:5432/verceldb?sslmode=require"

# Option 3: Local PostgreSQL Installation
# Update credentials to match your local PostgreSQL setup
# DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/yomu"

# =============================================================================
# NEXTAUTH CONFIGURATION
# =============================================================================

# Application URL (use localhost for local development)
NEXTAUTH_URL="http://localhost:3000"

# Secret for JWT encryption
# Generate with: openssl rand -base64 32
# IMPORTANT: Use a different secret in production!
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# =============================================================================
# OAUTH PROVIDERS (Optional)
# =============================================================================

# Google OAuth (Optional - only needed if enabling Google sign-in)
# Get credentials from: https://console.cloud.google.com/
# GOOGLE_CLIENT_ID="your-google-client-id-here"
# GOOGLE_CLIENT_SECRET="your-google-client-secret-here"

# =============================================================================
# DEVELOPMENT SETTINGS (Optional)
# =============================================================================

# Node environment (usually set by framework)
# NODE_ENV="development"

# Disable Next.js telemetry (optional)
# NEXT_TELEMETRY_DISABLED="1"

# Skip database push during builds (used in CI)
# SKIP_DB_PUSH="true"

# =============================================================================
# NOTES
# =============================================================================
# - Never commit this file with real credentials to version control
# - The .gitignore file already excludes .env.local files
# - For production deployment, use Vercel's environment variable dashboard
# - See CLAUDE.md for detailed PostgreSQL setup instructions
